---
interface VideoItem {
  title: string;
  youtubeId: string;
}

interface Props {
  heading?: string;
  videos: VideoItem[];
}

const { heading = 'Movies & Videos', videos } = Astro.props;
---

<section class="video-list-section" aria-labelledby="videos-heading">
  <h2 id="videos-heading" class="video-list-heading">{heading}</h2>
  <div class="video-list-grid">
    {videos.map((video) => (
      <article class="video-card">
        <div class="video-embed">
          <iframe
            src={`https://www.youtube.com/embed/${video.youtubeId}`}
            title={video.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
.video-list-section {
  margin-bottom: var(--space-12);
}

.video-list-heading {
  font-size: var(--font-size-2xl);
  color: var(--color-primary);
  margin-top: 0;
  margin-bottom: var(--space-6);
}

.video-list-grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.video-card {
  background: var(--color-white);
  border-radius: 16px;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  padding: var(--space-8);
}

.video-embed {
  position: relative;
  width: 100%;
  padding-top: 56.25%;
  border-radius: 12px;
  overflow: hidden;
  background: #000;
}

.video-embed iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}

@media (max-width: 768px) {
  .video-list-heading {
    font-size: var(--font-size-xl);
  }

  .video-card {
    padding: var(--space-6) var(--space-4);
  }
}
</style>
