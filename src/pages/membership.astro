---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Membership" description="Welcome to membership in the Minnesota Hoarding Task Force. Learn about membership types, benefits, and how to join.">

  <!-- Full-bleed hero banner -->
  <div class="hero-banner">
    <img src="/images/Member.png" alt="Interested in becoming a member of the Minnesota Hoarding Task Force?" />
  </div>

  <div class="page-content">
    <div class="container">

      <h1>Membership Information</h1>

      <!-- ── Membership Types ────────────────────────── -->
      <section class="mem-section">
        <h2 class="section-title">Types of Memberships</h2>

        <div class="type-cards">
          <div class="type-card">
            <div class="type-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3>Regular Membership</h3>
            <p>Completes and submits an annual membership form and pays annual dues. Regular Members can vote on group decisions and are able to serve on the Executive Board.</p>
            <div class="type-card-dues">$25 / year</div>
          </div>

          <div class="type-card">
            <div class="type-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <h3>Associate Membership</h3>
            <p>Completes and submits the annual membership form but does not pay annual dues. Associate Members do not have a vote on group decisions.</p>
            <div class="type-card-dues type-card-dues--free">Free</div>
          </div>

          <div class="type-card">
            <div class="type-card-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <h3>Board Membership</h3>
            <p>A member must be nominated or self-nominated during the end of the fiscal quarter when the present Director's 2-year term expires. Election occurs at a regular meeting; the new Director must receive a majority vote with a quorum as defined in the by-laws.</p>
            <div class="type-card-dues">By election</div>
          </div>
        </div>
      </section>

      <!-- ── Membership Details ──────────────────────── -->
      <section class="mem-section">
        <div class="detail-block">
          <h2 class="detail-heading">Membership Period</h2>
          <ul>
            <li>The membership year runs from May 1 – April 30</li>
            <li>You may join at any time during the year – (the fee is not prorated).</li>
            <li>The annual renewal for everyone is May 1</li>
          </ul>
        </div>

        <div class="detail-cols">
          <div class="detail-block">
            <h2 class="detail-heading">Privileges &amp; Benefits</h2>
            <ul>
              <li>Education through speakers and shared experiences</li>
              <li>Access to resources on Dropbox</li>
              <li>Vote at monthly meetings to have a voice</li>
              <li>Vote for election of officers or become one</li>
              <li>Use the MNHTF logo on your business website upon annual renewal review by board</li>
            </ul>
          </div>

          <div class="detail-block">
            <h2 class="detail-heading">Responsibilities</h2>
            <ul>
              <li>Use your talents and contacts to further the mission of the MNHTF – awareness, board development and fundraising</li>
              <li>Network</li>
              <li>Regularly attend monthly meetings (at least 4 per year)</li>
              <li>Use person-first language and maintain confidentiality of discussions at meetings</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- ── Join / Pricing CTA ─────────────────────── -->
      <section class="join-section">
        <div class="join-inner">
          <h2 class="join-title">Ready to Join?</h2>

          <div class="payment-methods">
            <div class="payment-method">
              <svg class="pay-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              <div>
                <strong>Credit Card</strong>
                <p>Pay securely online via <a href="https://givebutter.com/mnhtfmembershipdues" target="_blank" rel="noopener noreferrer">Givebutter</a></p>
              </div>
            </div>
            <div class="payment-method">
              <svg class="pay-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.6-.6a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21 16.92z"/></svg>
              <div>
                <strong>Check by Mail</strong>
                <p>P.O. Box 21483, Eagan, MN 55121</p>
              </div>
            </div>
          </div>

          <h3 class="pricing-label">Membership Options</h3>
          <div class="pricing-grid">
            <div class="pricing-item">
              <span class="pricing-type">Individual</span>
              <span class="pricing-amount">$25</span>
            </div>
            <div class="pricing-item">
              <span class="pricing-type">Single Proprietor Business</span>
              <span class="pricing-amount">$50</span>
            </div>
            <div class="pricing-item">
              <span class="pricing-type">Partnership or Larger Business</span>
              <span class="pricing-amount">$100</span>
            </div>
            <div class="pricing-item">
              <span class="pricing-type">Associate</span>
              <span class="pricing-amount pricing-amount--free">Free</span>
            </div>
          </div>

          <p class="pricing-note">Membership dues are renewed annually. Scholarships may be available for regular membership.</p>

          <div class="join-ctas">
            <a href="https://givebutter.com/mnhtfmembershipdues" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Pay Membership Dues</a>
          </div>

          <div class="form-links">
            <div class="form-link-item">
              <div class="form-link-label">Fill out our membership form online:</div>
              <a href="https://docs.google.com/forms/d/e/1FAIpQLScw8c_P9rqJwlLDa4L9XK8vhq_ziIhgFB9GhunKpxFIM70oDw/viewform?usp=header" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Electronic Form</a>
            </div>
            <div class="form-link-item">
              <div class="form-link-label">Print and mail your membership form (PDF):<br /><small>Email completed form to <a href="mailto:mnhtf.org@gmail.com">mnhtf.org@gmail.com</a></small></div>
              <a href="https://mnhtf.org/wp-content/uploads/2026/03/MNHTF-Membership-App-2026-Google-Forms.pdf" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Download Form (PDF)</a>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Group photo ─────────────────────────────── -->
      <div class="group-photo">
        <img src="/images/Mn-Hoarding-Task-Force-People.jpg" alt="Minnesota Hoarding Task Force members walking on a nature trail together" />
      </div>

    </div>
  </div>

</BaseLayout>

<style>
/* ── Base text ─────────────────────────────────────── */
p, li {
  font-size: var(--font-size-lg);
  color: var(--color-text);
  line-height: 1.75;
}
ul {
  padding-left: var(--space-6);
  margin: 0;
}
li {
  margin-bottom: var(--space-2);
}

/* ── Hero banner ───────────────────────────────────── */
.hero-banner {
  width: 100%;
  overflow: hidden;
}
.hero-banner img {
  width: 100%;
  height: auto;
  max-height: 320px;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* ── Page h1 ───────────────────────────────────────── */
h1 {
  font-size: var(--font-size-3xl);
  margin-bottom: var(--space-8);
}

/* ── Sections ──────────────────────────────────────── */
.mem-section {
  margin-bottom: var(--space-12);
}

/* ── Section title (h2 "Types of Memberships:") ────── */
.section-title {
  font-size: var(--font-size-2xl);
  color: var(--color-primary);
  text-decoration: underline;
  text-underline-offset: 4px;
  margin-bottom: var(--space-8);
}

/* ── Membership type cards ─────────────────────────── */
.type-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}
.type-card {
  background: var(--color-white);
  border: 1px solid #e0e4f0;
  border-radius: 12px;
  padding: var(--space-6);
  box-shadow: 0 4px 16px rgba(4, 12, 222, 0.07);
}
.type-card-icon {
  width: 48px;
  height: 48px;
  background: #eef0ff;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-4);
  color: var(--color-primary);
}
.type-card-icon svg {
  width: 24px;
  height: 24px;
  flex-shrink: 0;
}
.type-card h3 {
  font-size: var(--font-size-xl);
  color: var(--color-text-dark);
  margin-bottom: var(--space-3);
  font-weight: 700;
}
.type-card p {
  font-size: var(--font-size-base);
  flex: 1;
  margin-bottom: var(--space-4);
}
.type-card-dues {
  display: inline-block;
  background: var(--color-primary);
  color: white;
  font-size: var(--font-size-sm);
  font-weight: 700;
  padding: 4px 14px;
  border-radius: 20px;
  margin-top: var(--space-4);
}
.type-card-dues--free {
  background: var(--color-accent);
  color: var(--color-text-dark);
}

/* ── Detail sections ───────────────────────────────── */
.detail-heading {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-dark);
  text-decoration: underline;
  text-underline-offset: 4px;
  margin-bottom: var(--space-4);
}
.detail-block {
  margin-bottom: var(--space-8);
}
.detail-cols {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
}

/* ── Join / Pricing section ────────────────────────── */
.join-section {
  margin-bottom: var(--space-12);
}
.join-inner {
  background: linear-gradient(135deg, #eef0ff 0%, #f5f6ff 100%);
  border: 1px solid #d0d5f0;
  border-radius: 20px;
  padding: var(--space-8) var(--space-12);
}
.join-title {
  font-size: var(--font-size-2xl);
  color: var(--color-primary);
  margin-bottom: var(--space-6);
  text-decoration: underline;
  text-underline-offset: 4px;
}

/* Payment methods */
.payment-methods {
  display: flex;
  gap: var(--space-8);
  margin-bottom: var(--space-8);
  flex-wrap: wrap;
}
.payment-method {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
}
.pay-icon {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
  color: var(--color-primary);
  margin-top: 2px;
}
.payment-method strong {
  display: block;
  font-size: var(--font-size-lg);
  color: var(--color-text-dark);
  margin-bottom: var(--space-1);
}
.payment-method p {
  margin: 0;
  font-size: var(--font-size-base);
}

/* Pricing grid */
.pricing-label {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-dark);
  margin-bottom: var(--space-4);
}
.pricing-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-4);
  margin-bottom: var(--space-4);
}
.pricing-item {
  background: white;
  border: 1px solid #d0d5f0;
  border-radius: 10px;
  padding: var(--space-4);
  text-align: center;
  box-shadow: 0 2px 8px rgba(4, 12, 222, 0.06);
}
.pricing-type {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
  margin-bottom: var(--space-2);
  font-weight: 600;
}
.pricing-amount {
  display: block;
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-primary);
}
.pricing-amount--free {
  color: var(--color-accent-hover);
}
.pricing-note {
  font-size: var(--font-size-base);
  color: var(--color-secondary);
  font-style: italic;
  margin-bottom: var(--space-6);
}

/* CTAs */
.join-ctas {
  margin-bottom: var(--space-6);
}

/* Form links */
.form-links {
  display: flex;
  gap: var(--space-8);
  flex-wrap: wrap;
  padding-top: var(--space-6);
  border-top: 1px solid #d0d5f0;
}
.form-link-item {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.form-link-label {
  font-size: var(--font-size-base);
  color: var(--color-text-dark);
  font-weight: 600;
  line-height: 1.4;
}
.form-link-label small {
  display: block;
  font-weight: 400;
  color: var(--color-secondary);
  margin-top: 2px;
}

/* ── Group photo ───────────────────────────────────── */
.group-photo {
  margin-bottom: var(--space-8);
}
.group-photo img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 16px;
  box-shadow: 0 6px 24px rgba(0,0,0,0.12);
  max-height: 420px;
  object-fit: cover;
  object-position: center 30%;
}

/* ── Mobile ────────────────────────────────────────── */
@media (max-width: 900px) {
  .type-cards {
    grid-template-columns: 1fr;
  }
  .detail-cols {
    grid-template-columns: 1fr;
    gap: 0;
  }
  .pricing-grid {
    grid-template-columns: 1fr 1fr;
  }
  .join-inner {
    padding: var(--space-6);
  }
  .payment-methods {
    flex-direction: column;
    gap: var(--space-4);
  }
  .form-links {
    flex-direction: column;
    gap: var(--space-6);
  }
}
</style>
