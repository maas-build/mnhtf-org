---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Directory" description="Resources for individuals, families, and professionals dealing with hoarding disorder in Minnesota.">

  <div class="page-content">
    <div class="container">

      <p class="disclaimer"><em><strong>Disclaimer:</strong> The Minnesota Hoarding Task Force ("MN HTF") does not provide services directly. MN HTF provides resources and information regarding the general subject of hoarding. In doing so, MN HTF does not endorse, recommend, warrant, or assume any legal liability for the accuracy, completeness, or usefulness of any information, apparatus, product, or process.</em></p>

      <div class="download-section">
        <h2>Directory of Resources to Download:</h2>
        <p><a href="https://mnhtf.org/wp-content/uploads/2025/11/11_15_25-MN-Hoarding-Taskforce-Comprehensive-Resource-List-.xlsx.pdf" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Click here</a></p>
      </div>

      <div class="download-section">
        <h2>Donation Resource List to download:</h2>
        <p><a href="https://bridging.org/wp-content/uploads/2025/06/BridgingDonorResourceListRevApril25-1.pdf" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Click here</a></p>
      </div>

      <div class="brochure-section">
        <a href="/pdfs/MNHTF-Final-How-to-Help-Brochure.pdf" download>
          <img src="/images/Screenshot-2024-07-21-directory.png" alt="MN HTF How to Help Brochure" class="brochure-img" />
        </a>
      </div>

      <div class="youtube-cta">
        <p>Check Out Our YouTube Channel!</p>
        <a href="https://www.youtube.com/@mnhoardingtaskforce1757" target="_blank" rel="noopener noreferrer" class="btn btn-primary">MNHTF YouTube</a>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
.disclaimer {
  margin-bottom: var(--space-8);
  font-size: var(--font-size-sm);
  color: var(--color-text-muted);
}
.download-section {
  margin-bottom: var(--space-8);
}
.download-section h2 {
  margin-bottom: var(--space-3);
}
.brochure-section {
  margin: var(--space-8) 0;
  text-align: center;
}
.brochure-img {
  max-width: 100%;
  height: auto;
  display: inline-block;
}
.youtube-cta {
  margin: var(--space-8) 0;
  text-align: center;
}
.youtube-cta p {
  font-size: var(--font-size-xl);
  font-weight: 600;
  margin-bottom: var(--space-4);
}
</style>
