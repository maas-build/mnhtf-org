---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Coming Soon" description="This page is coming soon. Check back later for more resources.">

  <div class="page-content">
    <div class="container coming-soon-container">
      <h1>Coming Soon</h1>
      <p>We are working on resources for this section. Please check back soon.</p>
      <p>In the meantime, you can <a href="/contact/">contact us</a> with any questions or visit our <a href="/directory/">Resource Directory</a>.</p>
    </div>
  </div>

</BaseLayout>

<style>
.coming-soon-container {
  text-align: center;
  padding: var(--space-16) var(--space-4);
}
</style>
