---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---
<BaseLayout title="Contact Us" description="Contact the Minnesota Hoarding Task Force with questions, requests for support, or to get involved.">

  <h1 class="sr-only">Contact Us</h1>

  <!-- Full-bleed hero banner -->
  <div class="hero-banner">
    <img src="/images/Contact-Us.png" alt="Contact Us – Minnesota Hoarding Task Force" />
  </div>

  <div class="page-content">
    <div class="container">

      <!-- FAQ section -->
      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-inner">
          <ul class="faq-list">
            <li>
              <svg class="faq-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              <a href="/for-friends-and-family/">How to help a friend or loved one?</a>
            </li>
            <li>
              <svg class="faq-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              <a href="/for-people-who-hoard/">Where do I begin?</a>
            </li>
            <li>
              <svg class="faq-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              <a href="/for-friends-and-family/">Who can I contact if I am concerned about a Neighbor?</a>
            </li>
            <li>
              <svg class="faq-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              <a href="/directory/">Is there any direct service help at a low or no Cost?</a>
            </li>
            <li>
              <svg class="faq-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              <a href="/for-people-who-hoard/#support-groups">Are there Support Groups?</a>
            </li>
            <li>
              <svg class="faq-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              <a href="/for-people-who-hoard/#animal-hoarding">I have questions about Animal Hoarding?</a>
            </li>
            <li>
              <svg class="faq-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              <a href="/for-people-who-hoard/">I have questions about Hoarding and losing my housing?</a>
            </li>
          </ul>
          <div class="faq-photo">
            <img src="/images/Contact-Us-Woman-On-Phone.jpg" alt="Person using their phone to find resources" />
          </div>
        </div>
      </section>

      <!-- Contact form section -->
      <section class="form-section">
        <h2>Contact Us:</h2>
        <ContactForm />
      </section>

      <!-- Connect section -->
      <section class="connect-section">
        <div class="section-header">
          <h2>Connect with the Task Force</h2>
        </div>
        <div class="connect-grid">
          <a href="tel:6125685550" class="connect-item">
            <span class="connect-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <span class="connect-text">
              <span class="connect-label">Voicemail</span>
              <span class="connect-value">612-568-5550</span>
            </span>
          </a>
          <a href="mailto:mnhtf.org@gmail.com" class="connect-item">
            <span class="connect-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <span class="connect-text">
              <span class="connect-label">Email</span>
              <span class="connect-value">mnhtf.org@gmail.com</span>
            </span>
          </a>
          <a href="https://www.facebook.com/mnhtf/" target="_blank" rel="noopener noreferrer" class="connect-item">
            <span class="connect-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </span>
            <span class="connect-text">
              <span class="connect-label">Social</span>
              <span class="connect-value">Facebook</span>
            </span>
          </a>
          <div class="connect-item">
            <span class="connect-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span class="connect-text">
              <span class="connect-label">Mailing Address</span>
              <span class="connect-value">P.O. Box 21483, Eagan, MN 55121</span>
            </span>
          </div>
        </div>
      </section>

      <!-- Board section -->
      <section class="board-section">
        <div class="section-header">
          <h2>Task Force Executive Board</h2>
        </div>
        <div class="board-photos">
          <a href="https://mnhtf.org/wp-content/uploads/2023/01/Jennifer.jpg" target="_blank" rel="noopener noreferrer" class="board-photo-item">
            <img src="https://mnhtf.org/wp-content/uploads/2023/01/Jennifer.jpg" alt="Jennifer LeClaire Schmidt, President" width="140" height="140" />
            <span class="board-member-name">Jennifer LeClaire Schmidt</span>
            <span class="board-member-title">President</span>
          </a>
          <a href="https://mnhtf.org/wp-content/uploads/2023/01/Jacqui-1.jpg" target="_blank" rel="noopener noreferrer" class="board-photo-item">
            <img src="https://mnhtf.org/wp-content/uploads/2023/01/Jacqui-1.jpg" alt="Jacqui Mason, Vice President" width="140" height="140" />
            <span class="board-member-name">Jacqui Mason</span>
            <span class="board-member-title">Vice President Emeritus</span>
          </a>
          <a href="https://mnhtf.org/wp-content/uploads/2023/09/NEW-Gail1.jpg" target="_blank" rel="noopener noreferrer" class="board-photo-item">
            <img src="https://mnhtf.org/wp-content/uploads/2023/09/NEW-Gail1.jpg" alt="Gail Trenholm, Treasurer" width="140" height="140" />
            <span class="board-member-name">Gail Trenholm</span>
            <span class="board-member-title">Treasurer</span>
          </a>
          <a href="https://mnhtf.org/wp-content/uploads/2024/06/IMG_5717.jpg" target="_blank" rel="noopener noreferrer" class="board-photo-item">
            <img src="https://mnhtf.org/wp-content/uploads/2024/06/IMG_5717.jpg" alt="Annika Ewing, Secretary" width="140" height="140" />
            <span class="board-member-name">Annika Ewing</span>
            <span class="board-member-title">Secretary</span>
          </a>
          <a href="https://mnhtf.org/wp-content/uploads/2023/01/13.-Louise-Kurzeka-15-Edit3500px.jpg" target="_blank" rel="noopener noreferrer" class="board-photo-item">
            <img src="https://mnhtf.org/wp-content/uploads/2023/01/13.-Louise-Kurzeka-15-Edit3500px.jpg" alt="Louise Kurzeka, Communications Liaison" width="140" height="140" />
            <span class="board-member-name">Louise Kurzeka</span>
            <span class="board-member-title">Communications Liaison</span>
          </a>
          <a href="https://mnhtf.org/wp-content/uploads/2023/01/Emily_Cheesebrow_9283_WEBSIZE-003-headshot.jpg" target="_blank" rel="noopener noreferrer" class="board-photo-item">
            <img src="https://mnhtf.org/wp-content/uploads/2023/01/Emily_Cheesebrow_9283_WEBSIZE-003-headshot.jpg" alt="Emily Cheesebrow, President Emeritus" width="140" height="140" />
            <span class="board-member-name">Emily Cheesebrow</span>
            <span class="board-member-title">President Emeritus</span>
          </a>
        </div>
      </section>

    </div>
  </div>

</BaseLayout>

<style>
/* ── Accessibility ─────────────────────────────── */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

/* ── Hero banner ───────────────────────────────── */
.hero-banner {
  width: 100%;
  overflow: hidden;
}
.hero-banner img {
  width: 100%;
  height: auto;
  max-height: 320px;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* ── Quick contact cards ───────────────────────── */
.contact-quick-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
  margin-bottom: var(--space-12);
}
.qcard {
  background: var(--color-white);
  border-radius: 12px;
  padding: var(--space-8) var(--space-6);
  box-shadow: 0 2px 12px rgba(4, 12, 222, 0.08);
  border-top: 4px solid var(--color-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  text-decoration: none;
  color: var(--color-text-dark);
  transition: transform var(--transition), box-shadow var(--transition);
}
.qcard:not(.qcard-static):hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(4, 12, 222, 0.15);
  color: var(--color-text-dark);
}
.qcard-icon {
  width: 64px;
  height: 64px;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-4);
  color: var(--color-white);
  flex-shrink: 0;
}
.qcard-label {
  font-size: var(--font-size-sm);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-secondary);
  margin-bottom: var(--space-2);
}
.qcard-value {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-dark);
}

/* ── Section cards (vertical stack) ───────────── */
.faq-section,
.form-section,
.connect-section,
.board-section {
  background: var(--color-white);
  border-radius: 16px;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  padding: var(--space-12);
  margin-bottom: var(--space-8);
}
.board-section {
  margin-bottom: 0;
}

/* ── Section headings ──────────────────────────── */
.faq-section h2 {
  font-size: var(--font-size-3xl);
  color: var(--color-primary);
  margin-bottom: var(--space-8);
}
.form-section h2 {
  font-size: var(--font-size-3xl);
  color: var(--color-text-dark);
  margin-bottom: var(--space-8);
  text-transform: uppercase;
  letter-spacing: 0.03em;
}
.section-header {
  margin-bottom: var(--space-8);
  padding-bottom: var(--space-4);
  border-bottom: 3px solid var(--color-primary);
}
.section-header h2 {
  font-size: var(--font-size-3xl);
  color: var(--color-primary);
  margin: 0;
}

/* ── FAQ ───────────────────────────────────────── */
.faq-inner {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: var(--space-8);
  align-items: start;
}
.faq-list {
  list-style: none;
  margin: 0;
  padding: 0;
}
.faq-list li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  padding: var(--space-4) 0;
  border-bottom: 1px solid #f0f0f0;
}
.faq-list li:last-child {
  border-bottom: none;
}
.faq-arrow {
  flex-shrink: 0;
  margin-top: 4px;
  color: var(--color-primary);
}
.faq-list a {
  color: var(--color-primary);
  text-decoration: none;
  font-size: var(--font-size-xl);
  font-weight: 500;
  line-height: 1.4;
}
.faq-list a:hover {
  text-decoration: underline;
}
.faq-photo img {
  width: 100%;
  height: 340px;
  object-fit: cover;
  border-radius: 12px;
  display: block;
}

/* ── Connect section ───────────────────────────── */
.connect-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-2);
}
.connect-item {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-4) var(--space-3);
  border-radius: 8px;
  text-decoration: none;
  color: var(--color-text);
  transition: background var(--transition), color var(--transition);
}
a.connect-item:hover {
  background: #f0f2ff;
  color: var(--color-primary-dark);
}
.connect-icon {
  width: 52px;
  height: 52px;
  background: #eef0ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--color-primary);
}
.connect-text {
  display: flex;
  flex-direction: column;
}
.connect-label {
  font-size: var(--font-size-sm);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-secondary);
}
.connect-value {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-primary);
}

/* ── Board section ─────────────────────────────── */
.board-photos {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-8);
}
.board-photo-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  text-decoration: none;
  color: var(--color-text);
  text-align: center;
}
.board-photo-item img {
  width: 140px;
  height: 140px;
  object-fit: cover;
  border-radius: 50%;
  border: 3px solid var(--color-primary);
  display: block;
  transition: transform var(--transition), box-shadow var(--transition);
}
.board-photo-item:hover img {
  transform: scale(1.05);
  box-shadow: 0 4px 16px rgba(4, 12, 222, 0.25);
}
.board-member-name {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--color-text-dark);
  line-height: 1.3;
}
.board-member-title {
  font-size: var(--font-size-sm);
  color: var(--color-secondary);
}

/* ── Responsive ────────────────────────────────── */
@media (max-width: 960px) {
  .faq-inner {
    grid-template-columns: 1fr;
  }
  .faq-photo img {
    height: 280px;
  }
  .connect-grid {
    grid-template-columns: 1fr;
  }
  .board-photos {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (max-width: 600px) {
  .contact-quick-cards {
    grid-template-columns: 1fr;
  }
  .faq-section,
  .form-section,
  .connect-section,
  .board-section {
    padding: var(--space-8) var(--space-6);
  }
  .board-photos {
    gap: var(--space-6);
  }
}
</style>
